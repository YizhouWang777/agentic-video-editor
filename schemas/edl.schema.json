{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic-video-editor/edl.schema.json",
  "title": "Agentic Video Editor EDL",
  "type": "object",
  "required": ["version", "render", "segments"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string"
    },
    "render": {
      "type": "object",
      "required": ["width", "height", "fps"],
      "additionalProperties": true,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fps": {
          "type": "integer",
          "minimum": 1
        },
        "caption_style": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "start", "end"],
        "additionalProperties": true,
        "properties": {
          "source": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "beat": {
            "type": "string"
          },
          "volume": {
            "type": "number",
            "minimum": 0,
            "maximum": 4
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "captions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "additionalProperties": true,
        "properties": {
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "overlays": {
      "type": "array"
    }
  }
}
